# Max pages to paginate per search URL (each page ~25 listings)
MAX_PAGES_PER_URL = 2

# ── Database ─────────────────────────────────────────────────
DB_PATH = "radar.db"

# ── Fetching Parameters ──────────────────────────────────────
# Dubai location IDs for Bayut API (pre-mapped)
# Use the locations_search endpoint to find more
DUBAI_LOCATION_IDS = {
    "dubai":                "1",
    "business-bay":         "6901",
    "dubai-marina":         "5002",
    "downtown-dubai":       "6",
